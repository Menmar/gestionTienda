<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         CLIENTE: preferencias de notificación
         ================================================================ -->

    <changeSet id="v6-cliente-notificaciones" author="menmar">
        <addColumn tableName="cliente">
            <column name="notif_email" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notif_whatsapp" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notif_telegram" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="telegram_chat_id" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
